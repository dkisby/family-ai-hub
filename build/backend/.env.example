# Backend API Environment Variables
# Copy to .env for local development

# Port
PORT=3001

# Foundry (Azure OpenAI)
FOUNDRY_ENDPOINT=https://ai-family-hub.openai.azure.com
FOUNDRY_API_KEY=<your-api-key>

# Entra Configuration
ENTRA_TENANT_ID=<your-tenant-id>
# Optional: comma-separated Entra group object IDs that are allowed to use the app.
# When set, users must be in at least one listed group.
# Example: ENTRA_ALLOWED_GROUP_IDS=11111111-2222-3333-4444-555555555555,aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
ENTRA_ALLOWED_GROUP_IDS=

# Environment
NODE_ENV=development
